# Swift / SPM
client/.build/
client/.swiftpm/
client/Package.resolved

# Editor bundle (client/editor/): built output is committed as
# client/Sources/Resources/editor.html; these are rebuildable intermediates.
client/editor/node_modules/
client/editor/dist/

# macOS
.DS_Store
*.swp
*~

# IDE
.vscode/
.idea/
*.xcodeproj/
*.xcworkspace/

# Claude Code
.claude/

# Data (user-specific; workspace-folder documents are never in the repo either)
*.jsonl
*.offset

# Secrets
*.pem
*.p12
*.key

# Local benchmark fixtures + media (kept out of git — large/private meeting audio,
# e.g. the diarization-threshold tuning fixtures referenced in OfflineDiarizerHost.swift)
client/.fixtures/
videoplayback.mp4
meeting-temp.wav

# Marketing site build output — docs/ is regenerated by `npm run build` (source: site/) and
# deployed to Cloudflare via `wrangler deploy`. GitHub hosts nothing, so keep the build out of git.
docs/

# Release binaries — notarized DMGs + Sparkle update archives. Durably hosted on Cloudflare
# (voice.baselinemakes.com) and kept on disk locally; excluded from git to avoid history bloat.
site/static/downloads/
site/static/updates/

# Internal planning / strategy notes — local only, never published.
planning-notes/

# Wrangler local cache
.wrangler/

# Git worktrees (local isolated workspaces)
.worktrees/
